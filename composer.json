{
  "name": "arraypress/wp-register-onboarding",
  "version": "1.0.0",
  "description": "A declarative WordPress onboarding wizard registration system for plugin setup flows",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "homepage": "https://github.com/arraypress/wp-register-onboarding/",
  "authors": [
    {
      "name": "David Sherlock",
      "homepage": "https://arraypress.com/"
    }
  ],
  "require": {
    "php": ">=7.4",
    "arraypress/wp-composer-assets": "dev-main",
    "arraypress/wp-currencies": "dev-main",
    "arraypress/wp-countries": "dev-main"
  },
  "autoload": {
    "psr-4": {
      "ArrayPress\\RegisterOnboarding\\": "src/"
    },
    "files": [
      "src/Functions.php"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "preferred-install": "dist"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "support": {
    "issues": "https://github.com/arraypress/wp-register-onboarding/issues",
    "source": "https://github.com/arraypress/wp-register-onboarding"
  },
  "keywords": [
    "wordpress",
    "onboarding",
    "wizard",
    "setup",
    "first-run",
    "admin-interface",
    "wp-admin",
    "plugin-setup"
  ]
}
